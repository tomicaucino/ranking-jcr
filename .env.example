# Copiar a .env.local y completar con los datos de tu proyecto Supabase
# (Project Settings -> API).

# Project URL
NEXT_PUBLIC_SUPABASE_URL=

# "Publishable key" (proyectos nuevos) o "anon public" (proyectos viejos).
# Segura de exponer al navegador: las tablas están protegidas por RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# "Secret key" (proyectos nuevos) o "service_role" (proyectos viejos).
# NUNCA exponer al navegador. Solo se usa en Server Actions de administración.
SUPABASE_SECRET_KEY=
